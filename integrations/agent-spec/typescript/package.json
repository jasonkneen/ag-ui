{
  "name": "@ag-ui/agent-spec",
  "author": "@sonleoracle",
  "version": "0.0.1",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "git clean -fdX --exclude=\"!.env\"",
    "typecheck": "tsc --noEmit",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm unlink --global"
  },
  "peerDependencies": {
    "@ag-ui/core": ">=0.0.40",
    "@ag-ui/client": ">=0.0.40",
    "@ag-ui/a2ui-middleware": ">=0.0.1"
  },
  "devDependencies": {
    "@ag-ui/core": "workspace:*",
    "@ag-ui/client": "workspace:*",
    "@ag-ui/a2ui-middleware": "workspace:*",
    "@types/node": "^20.11.19",
    "tsdown": "^0.20.1",
    "typescript": "^5.3.3"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  }
}
